# Reproducibility: derive SOURCE_DATE_EPOCH from the (frozen) %changelog date and clamp file
# mtimes to it, and pin the recorded build host, so RPMs are byte-identical across build machines.
# These are redhat-rpm-config knobs, effective on Fedora/EL9+ (and on by default there); we set
# them explicitly so the intent is applied wherever supported. On toolchains that predate them or
# do not implement them (e.g. EL8, Amazon Linux, openSUSE's own SOURCE_DATE_EPOCH handling) an
# unrecognized global macro is simply ignored, so mtime/buildhost reproducibility is not guaranteed
# there.
%global source_date_epoch_from_changelog 1
%global clamp_mtime_to_source_date_epoch 1
%global _buildhost couchbase-reproducible-build

# gRPC support gate (grpc_supported).
#
# Some components link system gRPC + Protobuf. A platform can build ANY gRPC-based component only
# if it provides BOTH:
#   1. gRPC:     grpc-devel + grpc-plugins (the grpc_cpp_plugin protoc plugin), and
#   2. Protobuf: version >= 3.15. Our .proto schemas use proto3 "optional" fields, whose generated
#      has_*() accessors are only emitted by protobuf >= 3.15; older protobuf fails to compile
#      (e.g. EL9 ships protobuf 3.14 in CRB -> "has_as_json_object() was not declared").
#
# The platforms below are gated by gRPC/Protobuf availability -- NOT by any individual component.
# fit_performer is currently the only gRPC-based component packaged, but every future gRPC-based
# feature is expected to gate on grpc_supported and inherit this same matrix.
#
# Support matrix (versions are indicative and may drift; the load-bearing fact is protobuf >= 3.15):
#   - Fedora             grpc + protobuf >= 3.15 in repos     -> gRPC supported
#   - EL10+ (rocky/rhel) grpc (EPEL) + protobuf >= 3.15 (CRB) -> gRPC supported
#   - Amazon Linux 2023  grpc + protobuf >= 3.15 in repos     -> gRPC supported (only amzn root)
#   - EL9   (rocky/rhel) protobuf 3.14 in CRB                 -> no: protobuf too old
#   - EL8                no grpc packaged                     -> no: grpc unavailable
#   - openSUSE Leap 16   no grpc_cpp_plugin package; protobuf -> no: cannot generate grpc stubs
#                        28.x (major jump from 3.x)              from system grpc; protobuf 28
#                                                                also unvalidated
#
# To enable another distribution: confirm it provides grpc-devel, grpc-plugins, and
# protobuf-devel >= 3.15, then add it to the test below.
#
# The gate below matches any Amazon Linux; the only amzn build root is amazonlinux-2023, which meets
# the requirement. A tighter "amzn >= 2023" test is deliberately avoided: RPM's conditional
# expression parser treats the leading-zero form (02023) as octal, so that comparison is false on
# AL2023. If an older Amazon Linux is ever added as a root, verify it ships protobuf >= 3.15 first.
%if 0%{?fedora} > 0 || 0%{?rhel} >= 10 || 0%{?amzn}
%global grpc_supported 1
%endif

Name: couchbase-cxx-client
Summary: Couchbase C++ SDK
Version: @COUCHBASE_CXX_CLIENT_PACKAGE_VERSION@
Release: @COUCHBASE_CXX_CLIENT_PACKAGE_RELEASE@%{?dist}
Vendor: Couchbase, Inc.
Packager: Couchbase SDK Team <support@couchbase.com>
License: ASL 2.0
URL: https://docs.couchbase.com/cxx-sdk/current/hello-world/overview.html
%if 0%{?suse_version} == 1500
BuildRequires: gcc13, gcc13-c++
%else
BuildRequires: gcc, gcc-c++
%endif
BuildRequires: cmake >= 3.19
%if 0%{?suse_version} > 0
BuildRequires: libcurl-devel
BuildRequires: protobuf-devel
BuildRequires: nlohmann_json-devel
%else
%if 0%{?amzn} == 0 && (0%{?rhel} >= 9 || 0%{?fedora} > 0)
BuildRequires: curl-devel
BuildRequires: protobuf-devel
BuildRequires: json-devel
%else
# CentOS 8 / Rocky 8 - skip these packages (no OpenTelemetry)
%endif
%endif
%if 0%{?grpc_supported}
BuildRequires: grpc-devel
BuildRequires: grpc-plugins
# protobuf-devel is also pulled by the OpenTelemetry block above on most targets, but Amazon Linux
# skips that block (no OTel), so require it here to keep the gRPC build self-contained.
BuildRequires: protobuf-devel
BuildRequires: protobuf-compiler
%endif
Source0: @COUCHBASE_CXX_CLIENT_TARBALL_NAME@.tar.gz

%if 0%{?amzn}
# The additional linker flags break AmazonLinux
# https://bugzilla.redhat.com/show_bug.cgi?id=2043092
%undefine _package_note_flags
%endif

%description
This is the client and protocol library for Couchbase project.

%package tools
Summary: Couchbase C++ SDK, command line tools
Requires: %{name}%{?_isa} = %{version}-%{release}
%description -n %{name}-tools
CLI tools from the Couchbase C++ SDK.

%package devel
Summary: Couchbase C++ SDK, development files
Requires: %{name}%{?_isa} = %{version}-%{release}
%description devel
Development files for the Couchbase C++ SDK.

%if 0%{?grpc_supported}
%package fit-performer
Summary: Couchbase C++ SDK, FIT performer
Requires: %{name}%{?_isa} = %{version}-%{release}
%description fit-performer
FIT integration-test performer built against the Couchbase C++ SDK. It is
packaged separately so that nothing depends on it automatically; install it on
demand to run integration verification against the production SDK packages.
%endif

%prep
%autosetup -p1 -n@COUCHBASE_CXX_CLIENT_TARBALL_NAME@
%cmake \
%if 0%{?rhel} == 8 || 0%{?rocky} == 8 || 0%{?ol} == 8
    -S "." -B "redhat-linux-build" \
%endif
%if 0%{?suse_version} == 1500
    -DCMAKE_C_COMPILER=gcc-13 \
    -DCMAKE_CXX_COMPILER=g++-13 \
%endif
    -DBUILD_SHARED_LIBS=OFF \
    -DCOUCHBASE_CXX_CLIENT_INSTALL=ON \
    -DCOUCHBASE_CXX_CLIENT_STATIC_BORINGSSL=ON \
    -DCOUCHBASE_CXX_CLIENT_BUILD_EXAMPLES=OFF \
    -DCOUCHBASE_CXX_CLIENT_BUILD_TESTS=OFF \
%if 0%{?amzn} == 0 && (0%{?rhel} >= 9 || 0%{?fedora} > 0 || 0%{?suse_version} > 0)
    -DCOUCHBASE_CXX_CLIENT_BUILD_OPENTELEMETRY=ON \
%else
    -DCOUCHBASE_CXX_CLIENT_BUILD_OPENTELEMETRY=OFF \
%endif
    -DCOUCHBASE_CXX_CLIENT_BUILD_TOOLS=ON \
%if 0%{?grpc_supported}
    -DCOUCHBASE_CXX_CLIENT_BUILD_FIT_PERFORMER=ON \
%else
    -DCOUCHBASE_CXX_CLIENT_BUILD_FIT_PERFORMER=OFF \
%endif
    -DCOUCHBASE_CXX_CLIENT_BUILD_STATIC=ON \
    -DCOUCHBASE_CXX_CLIENT_BUILD_SHARED=ON

%build
%if 0%{?rhel} == 8 || 0%{?rocky} == 8 || 0%{?ol} == 8
/usr/bin/cmake --build "redhat-linux-build" -j${RPM_BUILD_NCPUS} --verbose
%else
%if 0%{?suse_version} == 1500
cd build
%endif
%cmake_build
%endif

%install
%if 0%{?rhel} == 8 || 0%{?rocky} == 8 || 0%{?ol} == 8
DESTDIR="%{buildroot}" /usr/bin/cmake --install "redhat-linux-build"
%else
%cmake_install
%endif
%if 0%{?suse_version} == 1500
%__mv %{buildroot}%{_docdir}/../tao %{buildroot}%{_docdir}/tao
%endif

%files
%license %{_docdir}/couchbase*/LICENSE.txt
%license %{_docdir}/tao/pegtl/LICENSE
%license %{_docdir}/tao/json/LICENSE
%{_libdir}/libcouchbase_cxx_client.so.*

%files tools
%{_bindir}/cbc

%files devel
%{_includedir}/couchbase
%{_includedir}/tao
%{_libdir}/cmake/*/*.cmake
%{_libdir}/libcouchbase_cxx_client.so
%{_libdir}/libcouchbase_cxx_client_static.a
%{_libdir}/pkgconfig/couchbase_cxx_client.pc
%{_libdir}/pkgconfig/couchbase_cxx_client_static.pc

%if 0%{?grpc_supported}
%files fit-performer
%{_bindir}/fit_performer
%endif

%changelog
* @COUCHBASE_CXX_CLIENT_RPM_DATE@ Couchbase SDK Team <support@couchbase.com> - @COUCHBASE_CXX_CLIENT_PACKAGE_VERSION@-@COUCHBASE_CXX_CLIENT_PACKAGE_RELEASE@
- Automated build.
